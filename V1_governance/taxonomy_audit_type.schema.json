{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$version": "1.0",
  "title": "Taxonomy Audit Type Governance Schema",
  "description": "Validates the structure of taxonomy_audit_type.json. Every entry must have id, label.en, short_label.en, description.en, sort_order, deprecated.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$version", "updated_at", "entries"],
  "properties": {
    "$version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "$schema": { "type": "string" },
    "updated_at": { "type": "string", "format": "date" },
    "id_convention": { "type": "string" },
    "description": { "type": "string" },
    "usage_notes": { "type": "array", "items": { "type": "string" } },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "short_label", "description", "sort_order", "deprecated"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ATYPE-[A-Z][A-Z0-9\\-]+$",
            "description": "SCREAMING-KEBAB with ATYPE- prefix."
          },
          "label": {
            "type": "object",
            "required": ["en"],
            "properties": { "en": { "type": "string", "minLength": 1 } },
            "additionalProperties": { "type": "string" }
          },
          "short_label": {
            "type": "object",
            "required": ["en"],
            "properties": { "en": { "type": "string", "minLength": 1 } },
            "additionalProperties": { "type": "string" }
          },
          "description": {
            "type": "object",
            "required": ["en"],
            "properties": { "en": { "type": "string", "minLength": 1 } },
            "additionalProperties": { "type": "string" }
          },
          "intosai_issai_ref": { "type": ["string", "null"] },
          "sort_order": { "type": "integer", "minimum": 1 },
          "deprecated": { "type": "boolean" },
          "superseded_by": { "type": ["string", "null"] }
        }
      }
    }
  }
}
