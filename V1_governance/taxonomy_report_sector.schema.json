{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$version": "1.0",
  "title": "Taxonomy Report Sector Governance Schema",
  "description": "Validates taxonomy_report_sector.json. Every entry must have id, label.en, short_label.en, level, cag_wing (from controlled list), sort_order, deprecated.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$version", "updated_at", "cag_wing_values", "entries"],
  "properties": {
    "$version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "$schema": { "type": "string" },
    "updated_at": { "type": "string", "format": "date" },
    "id_convention": { "type": "string" },
    "description": { "type": "string" },
    "usage_notes": { "type": "array", "items": { "type": "string" } },
    "cag_wing_values": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Controlled list of valid cag_wing values. Entry.cag_wing must be one of these."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "short_label", "level", "parent_id", "cag_wing", "sort_order", "deprecated"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SECT-[A-Z][A-Z0-9\\-]+$"
          },
          "label": {
            "type": "object",
            "required": ["en"],
            "properties": { "en": { "type": "string", "minLength": 1 } },
            "additionalProperties": { "type": "string" }
          },
          "short_label": {
            "type": "object",
            "required": ["en"],
            "properties": { "en": { "type": "string", "minLength": 1 } },
            "additionalProperties": { "type": "string" }
          },
          "level": { "type": "string", "enum": ["sector", "sub_sector"] },
          "parent_id": { "type": ["string", "null"] },
          "cag_wing": { "type": "string" },
          "description": {
            "type": "object",
            "required": ["en"],
            "properties": { "en": { "type": "string", "minLength": 1 } },
            "additionalProperties": { "type": "string" }
          },
          "sort_order": { "type": "integer", "minimum": 1 },
          "deprecated": { "type": "boolean" },
          "sub_sectors": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
