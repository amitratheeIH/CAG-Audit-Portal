  "description": "Registry of government entities for the CAG audit report repository. IDs are permanently stable — never change even if entity is renamed or restructured. active=false + archived=true for dissolved entities. v1.0: NITI Aayog corrected to level:advisory_body (was statutory_body — factual error, NITI Aayog is created by Cabinet Resolution not an Act). advisory_body added to level_values. GOI-MIN-PETROLEUM added. function_vocabulary extracted to taxonomy_entity_functions.json — this file retains a reference copy until migration is complete.",
  "id_convention": {
    "description": "ID prefix encodes jurisdiction and entity type. IDs must match pattern ^[A-Z0-9][A-Z0-9\\-]+[A-Z0-9]$",
    "prefixes": [
      { "prefix": "GOI-MIN", "meaning": "Central Government Ministry" },
      { "prefix": "GOI-DEPT", "meaning": "Central Government Department (under a Ministry)" },
      { "prefix": "GOI-OFF", "meaning": "Central Government Attached or Subordinate Office" },
      { "prefix": "GOI-PSU", "meaning": "Central Public Sector Undertaking" },
      { "prefix": "GOI-AUTH", "meaning": "Central Government Authority or Board" },
      { "prefix": "CONST", "meaning": "Constitutional Body (independent of executive)" },
      { "prefix": "STAT", "meaning": "Statutory Body (created by Act of Parliament)" },
      { "prefix": "ADVB", "meaning": "Advisory/Executive Body (created by Cabinet Resolution or executive order)" },
      { "prefix": "IN-{ST}-DEPT", "meaning": "State/UT Department — ST = ISO 3166-2 state code" },
      { "prefix": "IN-{ST}-PSU", "meaning": "State/UT Public Sector Undertaking" },
      { "prefix": "IN-{ST}-AUTH", "meaning": "State/UT Authority or Board" }
    ]
  },
  "level_values": [
    "ministry",
    "department",
    "attached_office",
    "subordinate_office",
    "authority",
    "board",
    "psu",
    "statutory_body",
    "constitutional_body",
    "advisory_body",
    "local_body"
  ],
