    "authority",
    "board",
    "commission",
    "corporation",
    "statutory_body",
    "constitutional_body",
    "autonomous_body",
    "advisory_body",
    "local_body"
  ],
  "level_entity_type_mapping": {
    "description": "Canonical mapping from level to valid entity_type values. Pipeline validates this pairing on ingest.",
    "ministry": ["ministry"],
    "department": ["department"],
    "attached_office": ["office"],
    "subordinate_office": ["office"],
    "authority": ["authority", "board", "commission"],
    "board": ["board", "authority"],
    "psu": ["psu", "corporation"],
    "statutory_body": ["statutory_body", "commission", "corporation", "autonomous_body"],
    "constitutional_body": ["constitutional_body"],
    "advisory_body": ["advisory_body", "commission"],
    "local_body": ["local_body"]
