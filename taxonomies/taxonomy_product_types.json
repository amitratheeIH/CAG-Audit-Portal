            "en": "Appropriation Accounts",
            "hi": "विनियोग लेखा"
          },
          "applicable_to_categories": [
            "union_accounts",
            "state_accounts"
          ],
          "description": "Appropriation Accounts — comparison of actual expenditure against Parliamentary/Legislative grants."
        },
        {
          "id": "combined",
          "label": {
            "en": "Combined (Finance + Appropriation)",
            "hi": "संयुक्त"
          },
          "applicable_to_categories": [
            "union_accounts",
            "state_accounts"
          ],
          "description": "Finance Accounts and Appropriation Accounts published as a single combined volume."
        }
      ],
      "portal_section": "accounts_reports"
    },
