          "jurisdiction": "LG",
          "local_body_type": "pri",
          "state_code": true,
          "lg_code": "optional",
          "portal_section": "finance_reports",
          "portal_url": "/finance/pri",
          "product_id_example": "SF02-CAG-2023-LG-MP or SF02-CAG-2023-LG-MP-ZPJABALPUR"
        }
