          "jurisdiction": "STATE or UT",
          "state_code": true,
          "lg_code": false,
          "portal_section": "finance_reports",
          "portal_url": "/finance/state",
          "product_id_example": "SF01-CAG-2023-STATE-MP"
        },
        {
          "id": "ulb_finance",
          "label": {
            "en": "ULB Finance Report",
