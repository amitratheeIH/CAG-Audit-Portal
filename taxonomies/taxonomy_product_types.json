{
  "$version": "1.0",
  "$schema": "./taxonomy_product_types.schema.json",
  "updated_at": "2025-01-01",
  "$schema_sync": {
    "target_schema": "common_metadata.schema",
    "target_field": "product_type.enum",
    "instruction": "The enum in common_metadata.schema must be kept in sync with the ids in this file. This is enforced by CI validation (scripts/validate_schema_enum_sync.py) — never edit the enum manually. The CI check runs on every commit and fails if the enum values diverge from the IDs in this file."
  },
  "description": {
    "en": "Controlled vocabulary for product_type field in common_metadata.schema. atn_applicable and pac_applicable flags are consumed by the ingestion pipeline to determine whether ATN and PAC tracking structures are expected.",
    "hi": "CAG भंडार उत्पाद प्रकारों के लिए नियंत्रित शब्दावली।"
  },
  "entries": [
    {
      "id": "audit_report",
      "label": {
        "en": "Audit Report",
        "hi": "लेखापरीक्षा प्रतिवेदन"
      },
      "atn_applicable": true,
      "pac_applicable": true,
      "jurisdiction_applicable": true,
      "valid_jurisdictions": [
        "UNION",
        "STATE",
        "UT",
        "LG"
      ],
      "jurisdiction_required": true,
      "accounts_sub_type_applicable": false,
      "description": "Compliance, performance, financial and other audit reports. Tabled in Parliament or State Legislature. Supports ATN and PAC tracking.",
      "portal_section": "audit_reports"
    },
    {
      "id": "accounts_report",
      "label": {
        "en": "Accounts Report",
        "hi": "लेखा प्रतिवेदन"
      },
      "prefix": "AC",
      "atn_applicable": false,
      "pac_applicable": false,
      "jurisdiction_applicable": true,
      "valid_jurisdictions": [
        "UNION",
        "STATE",
        "UT",
        "LG"
      ],
      "jurisdiction_required": true,
      "state_code_required_for": [
        "STATE",
        "UT",
        "LG"
      ],
      "lg_code_optional_for": [
        "LG"
      ],
      "accounts_sub_type_applicable": true,
      "description": "Annual government accounts. Four categories based on jurisdiction: union_accounts (UNION), state_accounts (STATE/UT), ulb_accounts (LG), pri_accounts (LG). accounts_sub_type (finance_accounts/appropriation_accounts/combined) applies to union_accounts and state_accounts only. ULB and PRI accounts do not have the finance/appropriation split. For LG: state_code always required; lg_code is optional (specific body or all LG in state).",
      "categories": [
        {
          "id": "union_accounts",
          "label": {
            "en": "Union Accounts",
            "hi": "संघ लेखा"
          },
          "jurisdiction": "UNION",
          "state_code": false,
          "lg_code": false,
          "accounts_sub_type_applicable": true,
          "portal_section": "accounts_reports",
          "portal_url": "/accounts/union",
          "product_id_example": "AC01-CAG-2023-UNION"
        },
        {
          "id": "state_accounts",
          "label": {
            "en": "State/UT Accounts",
            "hi": "राज्य/संघ राज्यक्षेत्र लेखा"
          },
          "jurisdiction": "STATE or UT",
          "state_code": true,
          "lg_code": false,
          "accounts_sub_type_applicable": true,
          "portal_section": "accounts_reports",
          "portal_url": "/accounts/state",
          "product_id_example": "AC01-CAG-2023-STATE-MP"
        },
        {
          "id": "ulb_accounts",
          "label": {
            "en": "ULB Accounts",
            "hi": "नगरीय स्थानीय निकाय लेखा"
          },
          "jurisdiction": "LG",
          "local_body_type": "ulb",
          "state_code": true,
          "lg_code": "optional",
          "accounts_sub_type_applicable": false,
          "portal_section": "accounts_reports",
          "portal_url": "/accounts/ulb",
          "product_id_example": "AC01-CAG-2023-LG-MP or AC01-CAG-2023-LG-MP-BBMP"
        },
        {
          "id": "pri_accounts",
          "label": {
            "en": "PRI Accounts",
            "hi": "पंचायती राज संस्था लेखा"
          },
          "jurisdiction": "LG",
          "local_body_type": "pri",
          "state_code": true,
          "lg_code": "optional",
          "accounts_sub_type_applicable": false,
          "portal_section": "accounts_reports",
          "portal_url": "/accounts/pri",
          "product_id_example": "AC02-CAG-2023-LG-MP or AC02-CAG-2023-LG-MP-ZPJABALPUR"
        }
      ],
      "accounts_sub_types": [
        {
          "id": "finance_accounts",
