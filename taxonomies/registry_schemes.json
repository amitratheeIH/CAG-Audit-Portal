    "description": "ID prefix encodes jurisdiction. IDs must match pattern ^[A-Z0-9][A-Z0-9\\-]+[A-Z0-9]$",
    "prefixes": [
      { "prefix": "GOI-SCH", "meaning": "Central Government Scheme / Programme / Mission" },
      { "prefix": "GOI-FUND", "meaning": "Central Government Fund or Corpus" },
      { "prefix": "IN-{ST}-SCH", "meaning": "State Scheme — ST = ISO 3166-2 state code e.g. IN-MP-SCH" }
    ]
  },
